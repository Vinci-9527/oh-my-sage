# oh-my-sage 配置文件

# ==================== LLM 配置 ====================

# OpenAI 兼容接口配置
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o

# 温度（可选，默认 0.7）
# LLM_TEMPERATURE=0.7

# ==================== 网关配置 ====================

# 米家网关地址
GATEWAY_URL=http://192.168.0.5
