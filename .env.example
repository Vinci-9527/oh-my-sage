# oh-my-sage 配置文件

# ==================== LLM 配置 ====================

# LLM Provider: qwen, kimi, openai, anthropic
LLM_PROVIDER=qwen

# Qwen (通义千问) 配置
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-max

# Kimi (月之暗面) 配置
# KIMI_API_KEY=your_kimi_api_key_here
# KIMI_MODEL=moonshot-v1-128k

# OpenAI 配置
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Anthropic 配置
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# LLM 参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ==================== 网关配置 ====================

# 米家网关地址
GATEWAY_URL=http://192.168.0.5

# 登录码（可选，也可以在使用时输入）
# GATEWAY_PASSCODE=123456
